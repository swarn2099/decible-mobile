{
  "expo": {
    "name": "Decibel",
    "slug": "decibel-mobile",
    "version": "1.0.0",
    "scheme": "decibel",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.decibel.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Decibel uses your location to detect when you're at a live show so you can collect the performing artists.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "instagram-stories",
          "instagram",
          "instagram-stories",
          "instagram"
        ]
      }
    },
    "android": {
      "package": "com.decibel.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-location",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44471fff-8ba1-46a0-9901-bdaf6ebef534"
      }
    },
    "owner": "swarn2099",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/44471fff-8ba1-46a0-9901-bdaf6ebef534"
    }
  }
}
