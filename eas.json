{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "TODO_SWARN_APPLE_ID_EMAIL",
        "ascAppId": "TODO_SWARN_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "TODO_SWARN_APPLE_TEAM_ID"
      }
    }
  }
}
